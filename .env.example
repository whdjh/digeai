# =============================================================================
# digeai 환경변수 예시. 이 파일을 .env로 복사 후 실제 값을 채워라.
# .env는 .gitignore에 포함되어 있으니 절대 커밋하지 마라.
# =============================================================================

# -----------------------------------------------------------------------------
# 클라이언트(브라우저)에 노출되어도 되는 값만 VITE_ prefix
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8888

# -----------------------------------------------------------------------------
# 서버 전용 시크릿 — 절대 VITE_ prefix 금지
# Vite는 VITE_* 변수를 클라이언트 번들에 인라인하므로 누구나 DevTools로 조회 가능.
# 이 값들은 Netlify Functions(`netlify/functions/*`) 또는 GitHub Actions에서
# process.env로만 읽어야 한다.
# -----------------------------------------------------------------------------

# Turso (libSQL) — subscribers 테이블 저장소
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Gemini — 뉴스 요약 (gemini-2.5-flash, @google/genai SDK)
GEMINI_API_KEY=

# Resend — 이메일 발송 (무료 3,000건/월)
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# 선택값
# -----------------------------------------------------------------------------

# RSSHub 호스트 (X 인플루언서 수집용). 미지정 시 https://rsshub.app 사용.
# 공개 인스턴스가 불안정하면 self-host(Render/Railway/Fly.io) URL로 교체.
RSSHUB_BASE_URL=

# 발신 이메일 주소 (Resend에서 도메인 인증한 것)
MAIL_FROM=Digeai <news@digeai.example.com>
